rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES DE APOIO ---

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.isDefaultAdmin == true;
    }

    function getPerms() {
      let profileId = request.auth.token.profileId;
      return get(/databases/$(database)/documents/profiles/$(profileId)).data.permissions;
    }

    // --- FUNÇÕES DE VALIDAÇÃO DE SCHEMA ---

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'profileId', 'assignedKioskIds'])
        && data.username is string
        && data.username.size() >= 3
        && data.email is string
        && data.profileId is string
        && data.assignedKioskIds is list;
    }

    function isValidLot(data) {
      return data.keys().hasAll(['kioskId', 'productId', 'quantity'])
        && data.kioskId is string
        && data.productId is string
        && data.quantity is number
        && data.quantity >= 0;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['baseName'])
        && data.baseName is string
        && data.baseName.size() >= 2;
    }

    function isValidBaseProduct(data) {
      return data.keys().hasAll(['name'])
        && data.name is string
        && data.name.size() >= 2;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status'])
        && data.title is string
        && data.title.size() >= 1
        && data.status is string;
    }

    function isValidReturnRequest(data) {
      return data.keys().hasAll(['status', 'createdAt'])
        && data.status is string;
    }

    function isValidPurchaseSession(data) {
      return data.keys().hasAll(['status', 'createdAt'])
        && data.status is string;
    }

    function isValidStockCount(data) {
      return data.keys().hasAll(['kioskId', 'status'])
        && data.kioskId is string
        && data.status is string;
    }

    function isValidMovement(data) {
      return data.keys().hasAll(['type', 'userId', 'timestamp'])
        && data.type is string
        && data.userId is string;
    }

    // --- REGRAS POR COLEÇÃO ---

    match /profiles/{profileId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || getPerms().settings.manageProfiles == true)
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.keys().hasAll(['name', 'permissions']);
      allow delete: if isAuth() && profileId != 'admin' && (isAdmin() || getPerms().settings.manageProfiles == true);
      allow update: if isAuth() && (isAdmin() || getPerms().settings.manageProfiles == true)
        && request.resource.data.name is string;
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || getPerms().settings.manageUsers == true)
        && isValidUser(request.resource.data);
      allow delete: if isAuth() && (isAdmin() || getPerms().settings.manageUsers == true);
      allow update: if isAuth() && (
        isAdmin() ||
        getPerms().settings.manageUsers == true ||
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['profileId']))
      ) && request.resource.data.username is string
        && request.resource.data.username.size() >= 3;
    }

    match /lots/{lotId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.inventoryControl.view == true);
      allow create: if isAuth() && (isAdmin() || getPerms().stock.inventoryControl.addLot == true)
        && isValidLot(request.resource.data);
      allow update: if isAuth() && (isAdmin() || getPerms().stock.inventoryControl.editLot == true || getPerms().stock.stockCount.approve == true)
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0;
      allow delete: if isAuth() && (isAdmin() || getPerms().stock.inventoryControl.writeDown == true);
    }

    match /products/{productId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || getPerms().registration.items.add == true)
        && isValidProduct(request.resource.data);
      allow update: if isAuth() && (isAdmin() || getPerms().registration.items.edit == true)
        && request.resource.data.baseName is string
        && request.resource.data.baseName.size() >= 2;
      allow delete: if isAuth() && (isAdmin() || getPerms().registration.items.delete == true);
    }

    match /baseProducts/{baseProductId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || getPerms().registration.baseProducts.add == true)
        && isValidBaseProduct(request.resource.data);
      allow update: if isAuth() && (isAdmin() || getPerms().registration.baseProducts.edit == true)
        && request.resource.data.name is string;
      allow delete: if isAuth() && (isAdmin() || getPerms().registration.baseProducts.delete == true);
    }

    match /productSimulations/{simId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || getPerms().pricing.simulate == true)
        && request.resource.data.keys().hasAll(['name'])
        && request.resource.data.name is string;
      allow delete: if isAuth() && (isAdmin() || getPerms().pricing.simulate == true);
    }

    match /productSimulationItems/{itemId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || getPerms().pricing.simulate == true)
        && request.resource.data.keys().hasAll(['simulationId'])
        && request.resource.data.simulationId is string;
      allow delete: if isAuth() && (isAdmin() || getPerms().pricing.simulate == true);
    }

    match /productSimulationCategories/{catId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isAdmin() || getPerms().pricing.manageParameters == true)
        && request.resource.data.name is string;
    }

    match /repositionActivities/{activityId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.analysis.restock == true);
      allow write: if isAuth() && (isAdmin() || getPerms().stock.analysis.restock == true)
        && request.resource.data.keys().hasAll(['status'])
        && request.resource.data.status is string;
    }

    match /returnRequests/{reqId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.returns.view == true);
      allow create: if isAuth() && (isAdmin() || getPerms().stock.returns.add == true)
        && isValidReturnRequest(request.resource.data);
      allow update: if isAuth() && (isAdmin() || getPerms().stock.returns.updateStatus == true)
        && request.resource.data.status is string;
      allow delete: if isAuth() && (isAdmin() || getPerms().stock.returns.delete == true);
    }

    match /stockAuditSessions/{sessionId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.stockCount.view == true);
      allow write: if isAuth() && (isAdmin() || getPerms().stock.stockCount.perform == true || getPerms().stock.stockCount.approve == true)
        && isValidStockCount(request.resource.data);
    }

    match /purchaseSessions/{sessionId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.purchasing.view == true);
      allow write: if isAuth() && (isAdmin() || getPerms().stock.purchasing.suggest == true || getPerms().stock.purchasing.approve == true)
        && isValidPurchaseSession(request.resource.data);
    }

    match /purchaseItems/{itemId} {
      allow read: if isAuth() && (isAdmin() || getPerms().stock.purchasing.view == true);
      allow write: if isAuth() && (isAdmin() || getPerms().stock.purchasing.suggest == true || getPerms().stock.purchasing.approve == true)
        && request.resource.data.keys().hasAll(['sessionId'])
        && request.resource.data.sessionId is string;
    }

    // ✅ CORRIGIDO: tasks agora exige permissão por perfil
    match /tasks/{taskId} {
      allow read: if isAuth() && (isAdmin() || getPerms().tasks.view == true);
      allow create, update: if isAuth() && (isAdmin() || getPerms().tasks.manage == true)
        && isValidTask(request.resource.data);
      allow delete: if isAuth() && (isAdmin() || getPerms().tasks.manage == true);
    }

    match /kiosks/{kioskId} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin()
        && request.resource.data.keys().hasAll(['name'])
        && request.resource.data.name is string;
    }

    match /movementHistory/{moveId} {
      allow read: if isAuth();
      allow create: if isAuth() && isValidMovement(request.resource.data);
      allow update, delete: if false;
    }

    match /priceHistory/{historyId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['productId', 'price'])
        && request.resource.data.price is number
        && request.resource.data.price >= 0;
      allow update, delete: if isAuth() && (isAdmin() || getPerms().stock.purchasing.deleteHistory == true);
    }

    match /simulationPriceHistory/{historyId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['simulationId'])
        && request.resource.data.simulationId is string;
      allow update, delete: if false;
    }

    // ✅ CORRIGIDO: catch-all bloqueia tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}