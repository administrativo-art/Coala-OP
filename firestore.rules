rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permite leitura e escrita por qualquer pessoa.
      // Isso é necessário para a primeira publicação, para o app poder criar os dados iniciais.
      // Depois da primeira publicação, vamos trocar por regras mais seguras.
      allow read, write: if true;
    }
  }
}
