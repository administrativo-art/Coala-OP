rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permite leitura e escrita por qualquer pessoa.
      // IMPORTANTE: Isso é para fins de desenvolvimento e para a primeira
      // inicialização. Você deve configurar regras mais seguras para produção.
      allow read, write: if true;
    }
  }
}
