
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES DE APOIO ---

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.isDefaultAdmin == true ||
        get(/databases/$(database)/documents/profiles/$(getProfileId())).data.isDefaultAdmin == true
      );
    }

    function getProfileId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileId != null
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileId
        : request.auth.token.profileId;
    }

    function getPerms() {
      let profileId = getProfileId();
      return get(/databases/$(database)/documents/profiles/$(profileId)).data.permissions;
    }

    // Acesso seguro ao domínio purchasing (perfis sem a chave retornam false)
    function purchasingPerm(key) {
      return getPerms().get('purchasing', {}).get(key, false) == true;
    }

    function canViewPurchasing() {
      return purchasingPerm('view') || getPerms().stock.purchasing.view == true;
    }

    function canCreateQuotation() {
      return purchasingPerm('createQuotation') || getPerms().stock.purchasing.suggest == true;
    }

    function canCreatePurchase() {
      return purchasingPerm('createPurchase') || getPerms().stock.purchasing.approve == true;
    }

    function canReceivePurchase() {
      return purchasingPerm('receivePurchase') || getPerms().stock.purchasing.approve == true;
    }

    // --- FUNÇÕES DE VALIDAÇÃO DE SCHEMA ---

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'profileId', 'assignedKioskIds'])
        && data.username is string
        && data.username.size() >= 3
        && data.email is string
        && data.profileId is string
        && data.assignedKioskIds is list;
    }

    function isValidLot(data) {
      return data.keys().hasAll(['kioskId', 'productId', 'quantity'])
        && data.kioskId is string
        && data.productId is string
        && data.quantity is number
        && data.quantity >= 0;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['baseName'])
        && data.baseName is string
        && data.baseName.size() >= 2;
    }

    function isValidBaseProduct(data) {
      return data.keys().hasAll(['name'])
        && data.name is string
        && data.name.size() >= 2;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status'])
        && data.title is string
        && data.title.size() >= 1
        && data.status is string;
    }

    function isValidReturnRequest(data) {
      return data.keys().hasAll(['status', 'createdAt'])
        && data.status is string;
    }

    function isValidPurchaseSession(data) {
      return data.keys().hasAll(['status', 'createdAt'])
        && data.status is string;
    }

    function isValidStockCount(data) {
      return data.keys().hasAll(['kioskId', 'status'])
        && data.kioskId is string
        && data.status is string;
    }

    function isValidMovement(data) {
      return data.keys().hasAll(['type', 'userId', 'timestamp'])
        && data.type is string
        && data.userId is string;
    }

    // --- REGRAS POR COLEÇÃO ---

    // Perfis
    match /profiles/{profileId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || getPerms().settings.manageProfiles == true)
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.keys().hasAll(['name', 'permissions'])
        && request.resource.data.permissions is map;
      allow update: if isAuth() && (isAdmin() || getPerms().settings.manageProfiles == true)
        && request.resource.data.name is string;
      allow delete: if isAuth() && profileId != 'admin'
        && (isAdmin() || getPerms().settings.manageProfiles == true);
    }

    // Usuários - Somente leitura via SDK, escrita via API
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Quiosques
    match /kiosks/{kioskId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Produtos - Somente leitura via SDK
    match /products/{productId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Produtos base
    match /baseProducts/{baseProductId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Entidades
    match /entities/{entityId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Lotes de estoque - Escrita restrita à API
    match /lots/{lotId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Histórico de movimentos
    match /movementHistory/{moveId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Sessões de contagem de estoque
    match /stockAuditSessions/{sessionId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Compras v2 - Bloqueio total de escrita direta
    match /quotations/{quotationId} {
      allow read: if isAuth();
      allow write: if false;
      match /items/{itemId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }

    match /purchase_orders/{orderId} {
      allow read: if isAuth();
      allow write: if false;
      match /items/{itemId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }

    match /purchase_receipts/{receiptId} {
      allow read: if isAuth();
      allow write: if false;
      match /items/{itemId} {
        allow read: if isAuth();
        allow write: if false;
        match /lots/{lotId} {
          allow read: if isAuth();
          allow write: if false;
        }
      }
    }

    match /purchase_financials/{financialId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /effective_cost_history/{entryId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Tarefas e Formulários
    match /tasks/{taskId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /task_projects/{projectId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /executions/{id} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /forms/{id} {
      allow read: if isAuth();
      allow write: if false;
    }

    // CATCH-ALL
    match /{document=**} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
