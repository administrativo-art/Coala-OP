rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatars — qualquer usuário autenticado lê, só o próprio usuário escreve
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Documentos de despacho — só autenticados
    match /dispatch/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Qualquer outro arquivo — só autenticados
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}