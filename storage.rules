rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatars — qualquer usuário autenticado lê, só o próprio usuário escreve
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Documentos de despacho — leitura autenticada, escrita só para admins
    match /dispatch/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isDefaultAdmin == true;
    }

    // Signage — uploads acontecem por rota server-side autenticada; arquivos são servidos por download token.
    match /signage/{allPaths=**} {
      allow read, write: if false;
    }

    // Qualquer outro arquivo — leitura autenticada, escrita negada por padrão
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
